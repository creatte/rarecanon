# ============================================================
# RareCanon 环境变量配置
# 复制此文件为 .env 后填入实际值
#   cp .env.example .env
# ============================================================

# ========== 应用 ==========
APP_NAME=RareCanon
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ========== 数据库 (PostgreSQL + pgvector) ==========
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rarecannon
POSTGRES_USER=rarecannon
POSTGRES_PASSWORD="change_me_please"
# 连接池配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# ========== Redis ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD="change_me_please"
REDIS_DB=0
# 连接池配置
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5

# ========== JWT 认证 ==========
JWT_SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ========== LLM 主推理模型 (DeepSeek) ==========
DEEPSEEK_API_KEY="change_me_please"
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# 推理参数
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60

# ========== Embedding 向量化 ==========
# 模式: api (DeepSeek API) 或 local (本地 sentence-transformers)
EMBEDDING_MODE="change_me_please"
# === api 模式 ===
EMBEDDING_API_KEY="change_me_please"
EMBEDDING_API_BASE="change_me_please"
EMBEDDING_API_MODEL="change_me_please"
# === local 模式 (EMBEDDING_MODE=local 时生效) ===
EMBEDDING_LOCAL_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_DIM=768
# 批量大小
EMBEDDING_BATCH_SIZE=32

# ========== RAG 检索 ==========
RAG_TOP_K=8
RAG_SIMILARITY_THRESHOLD=0.7
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_MAX_RETRIEVAL_ROUNDS=3

# ========== 会话 ==========
CONVERSATION_MAX_ROUNDS=20
SESSION_TTL_HOURS=2

# ========== 知识库文档目录 ==========
DATA_RAW_DIR=backend/data/raw
DATA_PROCESSED_DIR=backend/data/processed
